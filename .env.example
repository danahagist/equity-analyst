# Copy to .env if you use full-auto mode. .env is gitignored.
#
# NOT required for the default Claude-Code-native flow — there, Claude Code in
# VS Code performs the LLM seats on your Claude subscription (no API key).
#
# Only needed for `equity-analyst analyze TICKER` (the tool calls the
# Anthropic API itself; ~$0.35-0.60/ticker):
# ANTHROPIC_API_KEY=

# Optional overrides (defaults shown):
# EQUITY_ANALYST_DATA_DIR=./data
# EQUITY_ANALYST_OUTPUTS_DIR=./outputs

# Email delivery for `equity-analyst notify` (end of the weekly pipeline).
# Gmail: create an App Password (Account > Security > App Passwords), not your
# login password. Any SMTP host works. Leave unset to skip email.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com        # defaults to SMTP_USER
# SMTP_TO=you@gmail.com          # comma-separated for multiple recipients
